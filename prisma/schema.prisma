generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  passwordVersion Int     @default(1) @map("password_version")
  fullName     String?   @map("full_name") @db.VarChar(255)
  role         String    @default("user") @db.VarChar(50)
  phone        String?   @db.VarChar(20)
  avatar       String?   @db.VarChar(500)
  status       String    @default("offline") @db.VarChar(50)
  rating       Decimal   @default(5) @db.Decimal(2, 1)
  totalRevenue Decimal   @default(0) @map("total_revenue") @db.Decimal(15, 2)
  // Tỉ lệ quy đổi: 1 điểm = X tiền (mặc định 1000 VNĐ)
  profitRate   Decimal   @default(1000) @map("profit_rate") @db.Decimal(15, 2)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  trips        Trip[]
  createdTrips Trip[]      @relation("CreatedTrips")
  bookings     Booking[]
  notifications Notification[]
  settings     UserSettings?
  // Công thức mặc định cho Zom này
  formula     PricingFormula?  @relation(fields: [formulaId], references: [id])
  formulaId   Int?       @map("formula_id")
  // Nhiều công thức Zom này có thể dùng (quản lý trong API)
  formulaIds  Int[]      @map("formula_ids")

  @@index([email], name: "idx_users_email")
  @@index([phone], name: "idx_users_phone")
  @@index([status], name: "idx_users_status")
  @@index([formulaId], name: "idx_users_formula")
  @@map("users")
}

model Trip {
  id            Int       @id @default(autoincrement())
  title         String    @db.VarChar(255)
  description   String?  @db.Text
  departure     String    @map("departure") @db.VarChar(255)
  destination   String    @map("destination") @db.VarChar(255)
  departureTime DateTime  @map("departure_time") @db.Timestamptz
  arrivalTime   DateTime? @map("arrival_time") @db.Timestamptz
  price         Decimal   @db.Decimal(10, 2)
  profit        Decimal?  @db.Decimal(10, 2) // Lợi nhuận từ cuốc xe
  // Hướng đi: "oneway" (1 chiều) | "roundtrip" (2 chiều)
  tripDirection String    @default("oneway") @map("trip_direction") @db.VarChar(20)
  // Số điểm nhận được khi match công thức
  pointsEarned  Decimal?  @map("points_earned") @db.Decimal(10, 2)
  // Tỉ lệ quy đổi điểm→tiền tại thời điểm tạo trip (snapshot từ zom hoặc mặc định)
  profitRate    Decimal?  @map("profit_rate") @db.Decimal(15, 2)
  // ID công thức đã match
  matchedFormulaId Int?   @map("matched_formula_id")
  totalSeats    Int       @default(4) @map("total_seats")
  status        String    @default("scheduled") @db.VarChar(50)
  notes         String?   @db.Text
  driverId      Int?      @map("driver_id")
  driver        User?     @relation(fields: [driverId], references: [id])
  createdById   Int?      @map("created_by_id")
  createdBy     User?     @relation("CreatedTrips", fields: [createdById], references: [id])
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  bookings      Booking[]
  customers     TripCustomer[]

  @@index([driverId], name: "idx_trips_driver")
  @@index([departureTime], name: "idx_trips_departure_time")
  @@index([status], name: "idx_trips_status")
  @@map("trips")
}

model Booking {
  id          Int       @id @default(autoincrement())
  tripId      Int       @map("trip_id")
  trip        Trip      @relation(fields: [tripId], references: [id])
  passengerId Int       @map("passenger_id")
  passenger   User      @relation(fields: [passengerId], references: [id])
  seats       Int       @default(1)
  status      String    @default("pending") @db.VarChar(50)
  totalPrice  Decimal   @map("total_price") @db.Decimal(10, 2)
  notes       String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([tripId, passengerId], name: "idx_booking_trip_passenger")
  @@index([passengerId], name: "idx_bookings_passenger")
  @@index([tripId], name: "idx_bookings_trip")
  @@map("bookings")
}

model Customer {
  id          Int       @id @default(autoincrement())
  phone       String    @unique @db.VarChar(20)
  name        String    @db.VarChar(255)
  email       String?   @db.VarChar(255)
  notes       String?   @db.Text
  totalTrips  Int       @default(0) @map("total_trips")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  trips       TripCustomer[]

  @@index([phone], name: "idx_customers_phone")
  @@map("customers")
}

model TripCustomer {
  id          Int       @id @default(autoincrement())
  tripId      Int       @map("trip_id")
  trip        Trip      @relation(fields: [tripId], references: [id])
  customerId  Int       @map("customer_id")
  customer    Customer  @relation(fields: [customerId], references: [id])
  seats       Int       @default(1)
  status      String    @default("pending") @db.VarChar(50)
  notes       String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@unique([tripId, customerId], name: "idx_trip_customer_trip_customer")
  @@map("trip_customers")
}

model PushSubscription {
  id            Int       @id @default(autoincrement())
  userId        Int       @map("user_id")
  endpoint      String    @db.VarChar(500)
  p256dh        String    @map("p256dh") @db.VarChar(200)
  auth          String    @db.VarChar(100)
  userAgent     String?   @map("user_agent") @db.VarChar(500)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@index([userId], name: "idx_push_subscriptions_user")
  @@unique([endpoint], name: "idx_push_subscriptions_endpoint")
  @@map("push_subscriptions")
}

// Bảng lưu thông báo của người dùng
model Notification {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String    @default("reminder") @db.VarChar(50) // reminder, system, trip_update
  title       String    @db.VarChar(255)
  content     String    @db.Text
  data        Json?     // Dữ liệu bổ sung: { tripId, departureTime, ... }
  isRead      Boolean   @default(false) @map("is_read")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId, isRead], name: "idx_notifications_user_read")
  @@index([userId, createdAt], name: "idx_notifications_user_date")
  @@map("notifications")
}

// Bảng lưu cài đặt thông báo của người dùng
model UserSettings {
  id                    Int       @id @default(autoincrement())
  userId                Int       @unique @map("user_id")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  pushEnabled           Boolean   @default(true) @map("push_enabled")
  reminderOffset        Int       @default(60) @map("reminder_offset") // Phút trước khi nhắc (mặc định 60 phút)
  emailEnabled          Boolean   @default(true) @map("email_enabled")
  notificationHour      Int       @default(8) @map("notification_hour") // Giờ gửi thông báo tự động (0-23)
  quietHoursStart      Int?      @map("quiet_hours_start") // Bắt đầu giờ yên lặng
  quietHoursEnd        Int?      @map("quiet_hours_end") // Kết thúc giờ yên lặng
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@map("user_settings")
}

// Bảng lưu cấu hình hệ thống (Zalo OA, Email SMTP, etc)
model SystemSettings {
  id                    Int       @id @default(autoincrement())
  key                   String    @unique @db.VarChar(100)
  value                 String?   @db.Text
  description           String?   @map("description") @db.VarChar(500)
  category              String    @default("general") @map("category") @db.VarChar(50) // 'zalo', 'email', 'general'
  isSecret              Boolean   @default(false) @map("is_secret") // ẩn giá trị nhạy cảm
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@index([category], name: "idx_system_settings_category")
  @@map("system_settings")
}

// Danh mục trạng thái cuốc xe (quản lý trong Cài đặt)
model TripStatus {
  id         Int      @id @default(autoincrement())
  key        String   @unique @db.VarChar(50) // vd: scheduled, confirmed...
  label      String   @db.VarChar(100) // vd: Chờ gán
  color      String   @default("slate") @db.VarChar(30) // slate|blue|green|red|amber|purple...
  sortOrder  Int      @default(0) @map("sort_order")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([isActive, sortOrder], name: "idx_trip_status_active_order")
  @@map("trip_statuses")
}

// Template email (quản lý trong Cài đặt)
model EmailTemplate {
  id        Int      @id @default(autoincrement())
  key       String   @unique @db.VarChar(100) // vd: trip_reminder
  name      String   @db.VarChar(255)
  subject   String   @db.VarChar(255)
  body      String   @db.Text // plain text (có thể dùng {{var}})
  params    Json?    // danh sách biến hợp lệ + metadata
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([isActive], name: "idx_email_templates_active")
  @@map("email_templates")
}

// Bảng công thức tính điểm & lợi nhuận
// Mỗi công thức gồm: loại hình, giá đầu/cuối, số ghế, và số điểm nhận được
model PricingFormula {
  id            Int       @id @default(autoincrement())
  name          String    @db.VarChar(255) // Tên công thức (vd: "Ghép 4 ghế HN-HP 150k-250k")
  // Loại hình: "ghep" | "bao" | "bao_roundtrip"
  tripType      String    @map("trip_type") @db.VarChar(30)
  // Số ghế áp dụng: null = tất cả, 4 = xe 4 chỗ, 7 = xe 7 chỗ
  seats         Int?
  // Giá tối thiểu: null = không giới hạn, vd: 150000
  minPrice      Decimal?  @map("min_price") @db.Decimal(10, 2)
  // Giá tối đa: null = vô hạn, vd: 250000
  maxPrice      Decimal?  @map("max_price") @db.Decimal(10, 2)
  // Số điểm nhận được khi match công thức này
  points        Decimal   @default(1) @db.Decimal(10, 2)
  // Mô tả thêm (ghi chú nội bộ)
  description   String?   @db.Text
  // Công thức có đang active không
  isActive      Boolean   @default(true) @map("is_active")
  sortOrder     Int       @default(0) @map("sort_order")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Zom nào đang dùng công thức này (quản lý qua formulaIds ở User)
  zoms          User[]

  @@index([tripType], name: "idx_formulas_trip_type")
  @@index([isActive, sortOrder], name: "idx_formulas_active_order")
  @@map("pricing_formulas")
}

// Bảng lưu token reset mật khẩu
model PasswordReset {
  id          Int       @id @default(autoincrement())
  email       String    @db.VarChar(255)
  token       String    @unique @db.VarChar(255)
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz
  usedAt      DateTime? @map("used_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([email], name: "idx_password_reset_email")
  @@index([token], name: "idx_password_reset_token")
  @@map("password_resets")
}
